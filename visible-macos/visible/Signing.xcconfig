// macOS app signing config.
//
// The developer team is machine-specific, so it is NOT committed. To build the
// signed app locally (needed for keychain access — see the keychain-access-groups
// entitlement), create Signing.local.xcconfig next to this file with your team:
//
//   DEVELOPMENT_TEAM = ABCDE12345
//
// That file is gitignored. CI builds pass CODE_SIGNING_ALLOWED=NO, so no team is
// needed there, and this optional include is simply a no-op when the local file
// is absent.
#include? "Signing.local.xcconfig"
